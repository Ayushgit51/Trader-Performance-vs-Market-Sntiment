plt.subplot(1, 2, 1)
sns.boxplot(data=closed_trades, x='classification', y='Closed PnL', palette='Set2')
plt.title('PnL Distribution per Sentiment Category')
plt.axhline(0, color='red', linestyle='--', alpha=0.5)

