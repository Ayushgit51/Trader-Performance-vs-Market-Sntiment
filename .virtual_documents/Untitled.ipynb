plt.subplot(1, 2, 2)
closed_trades['Cumulative PnL'] = closed_trades['Closed PnL'].cumsum()
plt.plot(closed_trades['trade_date'], closed_trades['Cumulative PnL'], label='Equity Curve')
plt.title('Equity Curve vs. Market Context')
plt.xticks(rotation=45)

plt.tight_layout()
plt.show()


